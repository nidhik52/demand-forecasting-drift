# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Environment variables (never commit secrets) ──────────────────────────────
.env
*.env
!.env.example

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── MLflow (run artifacts too large to commit) ────────────────────────────────
mlruns/
mlartifacts/

# ── Raw data — keep only the source dataset ───────────────────────────────────
data/raw/*.xlsx
data/raw/*.parquet
# Track the two seed CSVs needed by the pipeline
!data/raw/sales_with_sku.csv
!data/raw/raw_data.csv

# ── Pipeline outputs (regenerated by pipeline.py) ────────────────────────────
data/processed/
data/drift_logs/

# ── Trained model artefacts ───────────────────────────────────────────────────
models/
*.pkl
*.joblib
*.h5

# ── React dashboard ───────────────────────────────────────────────────────────
dashboard/dist/
dashboard/node_modules/
dashboard/.vite/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
nohup.out

# ── Docker ────────────────────────────────────────────────────────────────────
docker/data/

# ── Reports ───────────────────────────────────────────────────────────────────
reports/figures/
reports/*.json

# ── Misc ──────────────────────────────────────────────────────────────────────
misc/
tmp/
.tmp/