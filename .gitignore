# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.env
*.env

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# MLflow (don't commit experiment runs — too large)
mlruns/
mlartifacts/

# Data files (don't commit raw/processed data to git)
data/raw/*.csv
# Allow the seed raw file — needed by master_data_pipeline.py in CI
!data/raw/sales_100k.csv
data/processed/*.csv
data/raw/*.xlsx
*.parquet

# BUT do commit drift logs and small reference files
!data/drift_logs/*.csv

# Models (can be large)
models/
*.pkl
*.joblib
*.h5

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Streamlit
.streamlit/secrets.toml

# Logs
*.log
logs/

# Docker
docker/data/
notebooks/mlruns/

# CI-generated reports (regenerated every run — never commit)
reports/drift_report*.json

# Misc files
misc/