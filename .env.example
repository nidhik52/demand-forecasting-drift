# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed as a template.

# ── MLflow ────────────────────────────────────────────────────────────────────
# Local file-based tracking (default — no server needed)
MLFLOW_TRACKING_URI=mlruns
# Uncomment to point at the Docker MLflow service
# MLFLOW_TRACKING_URI=http://localhost:5000

# ── Pipeline ──────────────────────────────────────────────────────────────────
RAW_DATA_PATH=data/raw/sales_with_sku.csv
PROCESSED_DIR=data/processed
DRIFT_LOG_DIR=data/drift_logs
MODELS_DIR=models

# ── Drift detection ───────────────────────────────────────────────────────────
MAE_THRESHOLD=20.0
ROLLING_WINDOW=14

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Dashboard ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
